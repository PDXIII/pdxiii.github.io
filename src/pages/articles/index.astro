---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import ArticleList from "../../components/ArticleList.astro";

const title = "Artikel";
const allArticles = await getCollection("articles", ({ data }) => !data.isDraft);

---

<Base title={title}>
  <section class="prose prose-lg px-8 mx-auto mb-8 min-h-[75vh]">
    <SectionHeader title="Artikel" image="Artikel-black.png" />
    
    <p>
      Hier findest Du eine Sammlung von Artikel, die ich über die Jahre geschrieben habe. Manche beinhalten UX Design Experimente, andere sind gar politisch.
    </p>
    <ArticleList allArticles={allArticles} />
  </section>
</Base>
